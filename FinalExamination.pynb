    {
      "cell_type": "markdown",
      "metadata": {
        "id": "d08d9428"
      },
      "source": [
        "**Reasoning**:\n",
        "I will apply the `extract_entities_detailed` function to the entire `Text` column and then count the occurrences of specific entity types (PERSON, ORGANIZATION, GPE) for each article, adding these as new features to the DataFrame.\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 1000
        },
        "id": "810f3dd2",
        "outputId": "2267add2-7b4e-49c9-c74f-224862c42405"
      },
      "source": [
        "import nltk\n",
        "from nltk import ne_chunk, pos_tag, word_tokenize\n",
        "from collections import Counter\n",
        "import pandas as pd\n",
        "\n",
        "# Ensure NLTK resources are available (already downloaded in previous cells, but good to ensure context)\n",
        "nltk.download('maxent_ne_chunker', quiet=True)\n",
        "nltk.download('words', quiet=True)\n",
        "nltk.download('maxent_ne_chunker_tab', quiet=True)\n",
        "nltk.download('punkt', quiet=True)\n",
        "nltk.download('averaged_perceptron_tagger', quiet=True)\n",
        "\n",
        "def extract_entities_detailed(text):\n",
        "    \"\"\"Extracts entities and their labels (PERSON, ORGANIZATION, GPE, etc.)\"\"\"\n",
        "    # Handle NaN or non-string inputs gracefully\n",
        "    if not isinstance(text, str):\n",
        "        return []\n",
        "    tokens = word_tokenize(text)\n",
        "    tags = pos_tag(tokens)\n",
        "    chunks = ne_chunk(tags)\n",
        "    entities = []\n",
        "    for chunk in chunks:\n",
        "        if hasattr(chunk, 'label'):\n",
        "            name = ' '.join(c[0] for c in chunk)\n",
        "            label = chunk.label()\n",
        "            entities.append({'name': name, 'label': label})\n",
        "    return entities\n",
        "\n",
        "# 3. Apply NER to the entire 'Text' column\n",
        "print(\"Applying Named Entity Recognition (NER) to all articles... This may take some time.\")\n",
        "df['entities_detailed'] = df['Text'].apply(extract_entities_detailed)\n",
        "print(\"NER application complete.\")\n",
        "\n",
        "# 4. Process extracted entities to create numerical features\n",
        "def count_entity_types(entity_list):\n",
        "    counts = Counter(entity['label'] for entity in entity_list)\n",
        "    return counts\n",
        "\n",
        "print(\"Counting entity types...\")\n",
        "df['entity_counts'] = df['entities_detailed'].apply(count_entity_types)\n",
        "\n",
        "# Extract counts for specific entity types as new columns\n",
        "df['num_person_entities'] = df['entity_counts'].apply(lambda x: x.get('PERSON', 0))\n",
        "df['num_organization_entities'] = df['entity_counts'].apply(lambda x: x.get('ORGANIZATION', 0))\n",
        "df['num_gpe_entities'] = df['entity_counts'].apply(lambda x: x.get('GPE', 0))\n",
        "print(\"Entity type counts added as features.\")\n",
        "\n",
        "# Display the first few rows with the new NER-based features\n",
        "display(df[['ArticleId', 'Category', 'num_person_entities', 'num_organization_entities', 'num_gpe_entities']].head())"
      ],
      "execution_count": 109,
