      "source": [
        "from sklearn.metrics import classification_report, confusion_matrix\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# 1. Make predictions on the X_test_retrained dataset\n",
        "y_pred_retrained = rf_model_retrained.predict(X_test_retrained)\n",
        "\n",
        "# 2. Print a classification report\n",
        "print(\"\\nModel Evaluation Report (Retrained Enhanced Features):\\n\")\n",
        "print(classification_report(y_test_retrained, y_pred_retrained))\n",
        "\n",
        "# 3. Generate confusion matrix\n",
        "cm_retrained = confusion_matrix(y_test_retrained, y_pred_retrained)\n",
        "\n",
        "# 4. Visualize the confusion matrix as a heatmap\n",
        "plt.figure(figsize=(10, 7))\n",
        "sns.heatmap(cm_retrained, annot=True, fmt='d', xticklabels=rf_model_retrained.classes_, yticklabels=rf_model_retrained.classes_, cmap='Blues')\n",
        "plt.title('Confusion Matrix (Retrained Enhanced Features): Predicted vs Actual Category')\n",
        "plt.ylabel('Actual')\n",
        "plt.xlabel('Predicted')\n",
        "plt.show()"
