      "source": [
        "**Reasoning**:\n",
        "Next, I will transform the `cleaned_misclassified_tech_article` using the `tfidf_ngrams` vectorizer and then identify the top 10 terms with the highest TF-IDF scores within this article. This addresses instructions 2 and 3 of the subtask.\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 355
        },
        "id": "9d4e373c",
        "outputId": "2c9d719f-22f7-4758-83c5-563c7fec44c0"
      },
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "# 2. Transform the cleaned_misclassified_tech_article using the tfidf_ngrams vectorizer\n",
        "# Ensure cleaned_misclassified_tech_article and tfidf_ngrams are available from previous cells\n",
        "if 'cleaned_misclassified_tech_article' in globals() and 'tfidf_ngrams' in globals():\n",
        "    # The vectorizer expects an iterable, so pass the cleaned text in a list\n",
        "    misclassified_article_tfidf = tfidf_ngrams.transform([cleaned_misclassified_tech_article])\n",
        "\n",
        "    # 3. Identify and display the top 10 terms with the highest TF-IDF scores within this specific misclassified article.\n",
        "    # Get feature names (terms) from the vectorizer\n",
        "    feature_names = tfidf_ngrams.get_feature_names_out()\n",
        "\n",
        "    # Get the TF-IDF scores for the misclassified article (it's a sparse matrix, convert to dense array)\n",
        "    article_scores = misclassified_article_tfidf.toarray().flatten()\n",
        "\n",
        "    # Create a DataFrame to sort and display top terms\n",
        "    article_terms_df = pd.DataFrame({\n",
        "        'term': feature_names,\n",
        "        'tfidf_score': article_scores\n",
        "    })\n",
        "\n",
        "    # Filter out terms with zero TF-IDF score and sort by score\n",
        "    article_terms_df = article_terms_df[article_terms_df['tfidf_score'] > 0].sort_values(by='tfidf_score', ascending=False)\n",
        "\n",
        "    print(f\"\\n--- Top 10 TF-IDF Terms in Misclassified 'Tech' Article: {cleaned_misclassified_tech_article} ---\")\n",
        "    display(article_terms_df.head(10))\n",
        "else:\n",
        "    print(\"Error: 'cleaned_misclassified_tech_article' or 'tfidf_ngrams' not found. Please ensure previous cells were executed.\")"
      ],
