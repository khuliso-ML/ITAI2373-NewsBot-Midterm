    {
      "cell_type": "markdown",
      "metadata": {
        "id": "a453c624"
      },
      "source": [
        "**Reasoning**:\n",
        "I will generate a Python code block to define the `get_bert_embeddings` function, apply it to the `cleaned_text` column of the DataFrame, and display the resulting BERT embeddings and their shape, as specified in the instructions.\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 290,
          "referenced_widgets": [
            "4c034ee3bc4f4f0ab12cedde76599905",
            "e5bd826c84194345aef5e842e4c92911",
            "9142e20374504ef5a57e2a6b53f1a055",
            "f1c3d551f16b4ad1a049cb5edeb71437",
            "880d485745cf4f44ba08ea8fb48243f7",
            "92ac9fe45fb94a93b4f260c5eaef1ce9",
            "7da482b732974f6ab7ea49e6334c3a32",
            "758cee15ff2745de99f7fcd3860e99e6",
            "d8aad4a986ee4fa38b8853148c3780e5",
            "ee7a02b144cb4efbb1c96cb47a8ada1b",
            "9250d3358e9149d098e6324221f474a1"
          ]
        },
        "id": "5f03fc4b",
        "outputId": "180588df-9b61-4b6b-ca3f-ed2e6a4467cd"
      },
      "source": [
        "import torch\n",
        "import numpy as np\n",
        "from tqdm.auto import tqdm # for progress bar\n",
        "\n",
        "# Ensure the model is in evaluation mode and moved to GPU if available\n",
        "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
        "model.to(device)\n",
        "model.eval()\n",
        "\n",
        "# Function to generate BERT embeddings\n",
        "def get_bert_embeddings(texts, tokenizer, model, device, max_length=128, batch_size=16):\n",
        "    all_embeddings = []\n",
        "    # Process texts in batches to prevent OOM errors and speed up inference\n",
        "    for i in tqdm(range(0, len(texts), batch_size), desc=\"Generating BERT embeddings\"):\n",
        "        batch_texts = texts[i:i+batch_size]\n",
        "\n",
        "        # Tokenize and encode texts\n",
        "        # Set truncation=True to handle texts longer than max_length\n",
        "        encoded_input = tokenizer(batch_texts, padding=True, truncation=True, max_length=max_length, return_tensors='pt')\n",
        "\n",
        "        # Move input tensors to the same device as the model\n",
        "        input_ids = encoded_input['input_ids'].to(device)\n",
        "        attention_mask = encoded_input['attention_mask'].to(device)\n",
        "\n",
        "        with torch.no_grad(): # Disable gradient calculations for inference\n",
        "            # Get the hidden states from the last layer\n",
        "            # `last_hidden_state` contains contextual embeddings for each token\n",
        "            # `pooler_output` is typically the embedding of the [CLS] token, often used for sequence classification\n",
        "            outputs = model(input_ids, attention_mask=attention_mask)\n",
        "            # We'll use the [CLS] token's embedding (pooler_output) as the sentence embedding\n",
        "            batch_embeddings = outputs.pooler_output.cpu().numpy()\n",
        "\n",
        "        all_embeddings.append(batch_embeddings)\n",
        "\n",
        "    return np.vstack(all_embeddings)\n",
        "\n",
        "\n",
        "print(\"Generating BERT embeddings for all cleaned articles...\")\n",
        "# Convert cleaned_text Series to a list for batch processing\n",
        "cleaned_text_list = df['cleaned_text'].tolist()\n",
        "\n",
        "# Generate embeddings\n",
        "bert_embeddings = get_bert_embeddings(cleaned_text_list, tokenizer, model, device)\n",
        "\n",
        "df['bert_embeddings'] = list(bert_embeddings) # Store embeddings as a list in a new DataFrame column\n",
        "\n",
        "print(f\"✅ BERT embeddings generated and added to DataFrame. Shape: {bert_embeddings.shape}\")\n",
        "print(\"Displaying the first few articles with their BERT embeddings (first 5 values):\")\n",
        "display(df[['ArticleId', 'Category', 'bert_embeddings']].head().map(lambda x: x[:5] if isinstance(x, np.ndarray) else x))"
      ],
      "execution_count": 132,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Generating BERT embeddings for all cleaned articles...\n"
          ]
        },
