      "source": [
        "import numpy as np\n",
        "\n",
        "# Get the actual test set indices relative to the original DataFrame\n",
        "# train_test_split returns shuffled indices, so we need to reconstruct the original indices for y_test_retrained\n",
        "# Assuming y_test_retrained corresponds to a subset of df.index\n",
        "# A more robust way would be to get indices directly from the split if they were returned by train_test_split.\n",
        "# For now, let's assume y_test_retrained is aligned with a subset of the original df.index or is derived from df.index during splitting.\n",
        "# Let's use the indices from y_test_retrained.index if it's a Series derived from df, or create an alignment if not.\n",
        "\n",
        "# In our case, y_test_retrained is a Series where its index corresponds to the original df index for the test set.\n",
        "original_test_indices = y_test_retrained.index\n",
        "\n",
        "# 1. Identify rows where the actual category was 'tech'\n",
        "actual_tech_mask = (y_test_retrained == 'tech')\n",
        "\n",
        "# 2. From these 'tech' articles, identify those where the predicted category was 'business' or 'entertainment'\n",
        "misclassified_mask = (\n",
        "    (y_pred_retrained == 'business') |\n",
        "    (y_pred_retrained == 'entertainment')\n",
        ")\n",
        "\n",
        "# Combine masks to find 'tech' articles misclassified as 'business' or 'entertainment'\n",
        "tech_misclassified_indices = original_test_indices[actual_tech_mask & misclassified_mask]\n",
        "\n",
        "print(f\"Indices of 'tech' articles misclassified as 'business' or 'entertainment':\\n{tech_misclassified_indices.tolist()}\")\n",
