      },
      "source": [
        "from sklearn.preprocessing import StandardScaler\n",
        "\n",
        "print(\"Applying StandardScaler to additional features...\")\n",
        "\n",
        "# 1. Instantiate StandardScaler\n",
        "scaler = StandardScaler()\n",
        "\n",
        "# 2. Fit and transform the additional_features_df\n",
        "scaled_additional_features = scaler.fit_transform(additional_features_df)\n",
        "\n",
        "# Optionally, convert back to DataFrame with original column names for inspection\n",
        "scaled_additional_features_df = pd.DataFrame(scaled_additional_features, columns=additional_features_df.columns)\n",
        "\n",
        "print(\"Scaled additional features created. Displaying head of scaled DataFrame:\")\n",
        "display(scaled_additional_features_df.head())"
      ],
