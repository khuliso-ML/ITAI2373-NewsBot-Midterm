    {
      "cell_type": "markdown",
      "metadata": {
        "id": "7f864a0b"
      },
      "source": [
        "**Reasoning**:\n",
        "To pinpoint the categories with which 'tech' and 'sport' are actually being confused, I will access the `cm_ngrams_1_3` confusion matrix and the `category_order` list. I'll then iterate through the relevant rows and columns to identify and list the categories contributing to False Positives and False Negatives for 'sport' and 'tech', as well as where any single misclassified articles landed.\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "eab5e149",
        "outputId": "6d688f59-6dae-40d3-c424-ceb6e39b93b9"
      },
      "source": [
        "import numpy as np\n",
        "\n",
        "# Re-define category_order and cm_ngrams_1_3 for clarity, ensuring they are accessible\n",
        "# (Assuming they are available in the kernel from previous executions)\n",
        "category_order = ['business', 'entertainment', 'politics', 'sport', 'tech']\n",
        "\n",
        "# cm_ngrams_1_3 variable is available from previous cells.\n",
        "# For illustration, if it were not, it would need to be re-created like this:\n",
        "# from sklearn.metrics import confusion_matrix\n",
        "# cm_ngrams_1_3 = confusion_matrix(y_test_1_3, y_pred_ngrams_1_3, labels=category_order)\n",
        "\n",
        "sport_idx = category_order.index('sport') # 3\n",
        "tech_idx = category_order.index('tech')   # 4\n",
        "\n",
        "print(f\"Category order: {category_order}\")\n",
        "print(f\"'Sport' index: {sport_idx}\")\n",
        "print(f\"'Tech' index: {tech_idx}\")\n",
        "print(f\"\\nFull Confusion Matrix:\\n{cm_ngrams_1_3}\")\n",
        "\n",
        "# 1. Categories incorrectly predicted as 'sport' (False Positives for 'sport')\n",
        "fp_for_sport_categories = []\n",
        "for i, actual_cat in enumerate(category_order):\n",
        "    if i == sport_idx: # Skip the 'sport' row itself (True Positives)\n",
        "        continue\n",
        "    if cm_ngrams_1_3[i, sport_idx] > 0:\n",
        "        fp_for_sport_categories.append(f\"{actual_cat} ({cm_ngrams_1_3[i, sport_idx]} articles)\")\n",
        "\n",
        "print(f\"\\n1. Categories incorrectly predicted as 'sport' (False Positives for sport):\\n   {', '.join(fp_for_sport_categories) if fp_for_sport_categories else 'None'}\")\n",
        "\n",
        "# 2. Categories incorrectly predicted as 'tech' (False Positives for 'tech')\n",
        "fp_for_tech_categories = []\n",
        "for i, actual_cat in enumerate(category_order):\n",
        "    if i == tech_idx: # Skip the 'tech' row itself (True Positives)\n",
        "        continue\n",
        "    if cm_ngrams_1_3[i, tech_idx] > 0:\n",
        "        fp_for_tech_categories.append(f\"{actual_cat} ({cm_ngrams_1_3[i, tech_idx]} articles)\")\n",
        "\n",
        "print(f\"\\n2. Categories incorrectly predicted as 'tech' (False Positives for tech):\\n   {', '.join(fp_for_tech_categories) if fp_for_tech_categories else 'None'}\")\n",
        "\n",
        "# 3. For the 1 'sport' article that was a False Negative, identify which category it was misclassified as.\n",
        "fn_sport_misclassified_as = []\n",
        "for j, predicted_cat in enumerate(category_order):\n",
        "    if j == sport_idx: # Skip the 'sport' column itself (True Positives)\n",
        "        continue\n",
        "    if cm_ngrams_1_3[sport_idx, j] > 0:\n",
        "        fn_sport_misclassified_as.append(f\"{predicted_cat} ({cm_ngrams_1_3[sport_idx, j]} articles)\")\n",
        "\n",
        "print(f\"\\n3. 'Sport' articles (False Negatives) misclassified as:\\n   {', '.join(fn_sport_misclassified_as) if fn_sport_misclassified_as else 'None'}\")\n",
        "\n",
        "\n",
        "# 4. For the 4 'tech' articles that were False Negatives, identify which categories they were misclassified as.\n",
        "fn_tech_misclassified_as = []\n",
        "for j, predicted_cat in enumerate(category_order):\n",
        "    if j == tech_idx: # Skip the 'tech' column itself (True Positives)\n",
        "        continue\n",
        "    if cm_ngrams_1_3[tech_idx, j] > 0:\n",
        "        fn_tech_misclassified_as.append(f\"{predicted_cat} ({cm_ngrams_1_3[tech_idx, j]} articles)\")\n",
        "\n",
        "print(f\"\\n4. 'Tech' articles (False Negatives) misclassified as:\\n   {', '.join(fn_tech_misclassified_as) if fn_tech_misclassified_as else 'None'}\")"
      ],
