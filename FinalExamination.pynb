    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "09da8c65",
        "outputId": "bb8c7ca8-94dd-4da5-cc20-c2e18ff96639"
      },
      "source": [
        "with open('main.py', 'r') as f:\n",
        "    main_py_content = f.read()\n",
        "\n",
        "print(main_py_content)"
      ],
      "execution_count": 123,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "import uvicorn\n",
            "from fastapi import FastAPI, Request, HTTPException\n",
            "from contextlib import asynccontextmanager\n",
            "from pydantic import BaseModel\n",
            "from typing import Dict\n",
            "import joblib\n",
            "import re\n",
            "import nltk\n",
            "from nltk.corpus import stopwords\n",
            "from nltk.stem import WordNetLemmatizer\n",
            "from nltk.tokenize import word_tokenize\n",
            "import os\n",
            "import logging\n",
            "from pythonjsonlogger import jsonlogger\n",
            "import time\n",
            "from prometheus_client import generate_latest, Counter, Histogram\n",
            "from starlette.responses import Response\n",
            "\n",
            "# --- Logging Setup ---\n",
            "# Configure logger\n",
            "logger = logging.getLogger(__name__)\n",
            "logger.setLevel(logging.INFO)\n",
            "\n",
            "# Create a JSON formatter\n",
            "logHandler = logging.StreamHandler()\n",
            "formatter = jsonlogger.JsonFormatter(\n",
            "    '%(levelname)s %(asctime)s %(name)s %(process)d %(message)s'\n",
            ")\n",
            "logHandler.setFormatter(formatter)\n",
            "logger.addHandler(logHandler)\n",
            "\n",
            "# --- NLTK Downloads and Preprocessing Function ---\n",
            "nltk.download('punkt', quiet=True)\n",
            "nltk.download('punkt_tab', quiet=True)\n",
            "nltk.download('stopwords', quiet=True)\n",
            "nltk.download('wordnet', quiet=True)\n",
            "nltk.download('omw-1.4', quiet=True)\n",
            "\n",
            "stop_words = set(stopwords.words('english'))\n",
            "lemmatizer = WordNetLemmatizer()\n",
            "\n",
            "# Global variables to store the loaded model and vectorizer\n",
            "rf_model = None\n",
            "tfidf_ngrams = None\n",
            "\n",
            "# Define paths for the model and vectorizer files\n",
            "# FIX: Use absolute path for Colab environment\n",
            "MODEL_PATH = '/content/newsbot_classifier.pkl'\n",
            "VECTORIZER_PATH = '/content/newsbot_vectorizer.pkl'\n",
            "\n",
            "# --- Prometheus Metrics ---\n",
            "PREDICTION_COUNT = Counter('newsbot_predictions_total', 'Total number of news category predictions', ['category'])\n",
            "PREDICTION_LATENCY = Histogram('newsbot_prediction_latency_seconds', 'Latency of prediction requests')\n",
            "\n",
            "def preprocess_text(text):\n",
            "    # Lowercase and remove special characters/numbers\n",
            "    text = re.sub(r'[^a-zA-Z\\s]', '', text.lower())\n",
            "    # Tokenization\n",
            "    tokens = word_tokenize(text)\n",
            "    # Stop word removal and Lemmatization\n",
            "    cleaned_tokens = [lemmatizer.lemmatize(w) for w in tokens if w not in stop_words]\n",
            "    return ' '.join(cleaned_tokens)\n",
            "\n",
            "# --- FastAPI Lifespan Context Manager ---\n",
            "@asynccontextmanager\n",
            "async def lifespan(app: FastAPI):\n",
            "    global rf_model, tfidf_ngrams\n",
            "    logger.info(\"Loading ML models...\")\n",
            "    if os.path.exists(MODEL_PATH) and os.path.exists(VECTORIZER_PATH):\n",
            "        rf_model = joblib.load(MODEL_PATH)\n",
            "        tfidf_ngrams = joblib.load(VECTORIZER_PATH)\n",
            "        logger.info(f\"Successfully loaded model: {MODEL_PATH}\")\n",
            "        logger.info(f\"Successfully loaded vectorizer: {VECTORIZER_PATH}\")\n",
            "    else:\n",
            "        logger.critical(f\"Error: Model or vectorizer files not found. Ensure '{MODEL_PATH}' and '{VECTORIZER_PATH}' exist.\")\n",
            "        raise RuntimeError(\"ML models not found\")\n",
            "    yield\n",
            "    logger.info(\"Shutting down application...\")\n",
            "\n",
            "# --- FastAPI App Initialization ---\n",
            "app = FastAPI(lifespan=lifespan,\n",
            "              title=\"NewsBot Intelligence System API\",\n",
            "              description=\"API for news article categorization using NLP and Machine Learning.\",\n",
            "              version=\"1.0.0\")\n",
            "\n",
            "# --- Pydantic Model for Request Body ---\n",
            "class TextInput(BaseModel):\n",
            "    text: str\n",
            "\n",
            "# --- API Endpoints ---\n",
            "@app.post(\"/predict\", response_model=Dict[str, str])\n",
            "async def predict_category(request: Request, input_data: TextInput):\n",
            "    \"\"\"\n",
            "    Predicts the news category for a given text input.\n",
            "\n",
            "    - **input_data**: A `TextInput` object containing the news article text.\n",
            "    - **Returns**: A JSON response with the predicted category.\n",
            "    \"\"\"\n",
            "    start_time = time.time()\n",
            "    request_id = str(time.time())\n",
            "    logger.info(\"Prediction request received\", extra={\n",
            "        \"request_id\": request_id,\n",
            "        \"client_host\": request.client.host,\n",
            "        \"text_length\": len(input_data.text)\n",
            "    })\n",
            "\n",
            "    if rf_model is None or tfidf_ngrams is None:\n",
            "        logger.error(\"Prediction failed: ML models not loaded\", extra={\n",
            "            \"request_id\": request_id,\n",
            "            \"status_code\": 500\n",
            "        })\n",
            "        raise HTTPException(status_code=500, detail=\"ML models not loaded. Please check server logs.\")\n",
            "\n",
            "    try:\n",
            "        # Preprocess the input text\n",
            "        cleaned_text = preprocess_text(input_data.text)\n",
            "\n",
            "        # Vectorize the cleaned text\n",
            "        vectorized_text = tfidf_ngrams.transform([cleaned_text])\n",
            "\n",
            "        # Make prediction\n",
            "        predicted_category = rf_model.predict(vectorized_text)[0]\n",
            "        prediction_time = time.time() - start_time\n",
            "\n",
            "        # Increment Prometheus metrics\n",
            "        PREDICTION_COUNT.labels(category=predicted_category).inc()\n",
            "        PREDICTION_LATENCY.observe(prediction_time)\n",
            "\n",
            "        logger.info(\"Prediction successful\", extra={\n",
            "            \"request_id\": request_id,\n",
            "            \"predicted_category\": predicted_category,\n",
            "            \"prediction_latency_ms\": prediction_time * 1000\n",
            "        })\n",
            "        return {\"category\": predicted_category}\n",
            "\n",
            "    except Exception as e:\n",
            "        logger.error(\"Prediction failed due to an internal error\", extra={\n",
            "            \"request_id\": request_id,\n",
            "            \"error_message\": str(e),\n",
            "            \"status_code\": 500\n",
            "        })\n",
            "        raise HTTPException(status_code=500, detail=f\"Internal server error: {e}\")\n",
            "\n",
            "@app.get(\"/\", summary=\"Root Endpoint\")\n",
            "async def root():\n",
            "    \"\"\"\n",
            "    Returns a welcome message and a link to the API documentation.\n",
            "    \"\"\"\n",
            "    return {\"message\": \"Welcome to the NewsBot Intelligence System API. Visit /docs for interactive API documentation.\"}\n",
            "\n",
            "@app.get(\"/health\", summary=\"Health Check Endpoint\")\n",
            "async def health_check():\n",
            "    \"\"\"\n",
            "    Performs a health check to ensure the API is running and models are loaded.\n",
            "    \"\"\"\n",
            "    if rf_model is not None and tfidf_ngrams is not None:\n",
            "        logger.info(\"Health check successful: Models loaded.\", extra={\"status\": \"healthy\"})\n",
            "        return {\"status\": \"healthy\", \"message\": \"API is running and models are loaded.\"}\n",
            "    else:\n",
            "        logger.error(\"Health check failed: Models not loaded.\", extra={\"status\": \"unhealthy\"})\n",
            "        raise HTTPException(status_code=503, detail=\"API is running but ML models are not loaded.\")\n",
            "\n",
            "@app.get(\"/metrics\", summary=\"Prometheus Metrics Endpoint\")\n",
            "async def metrics():\n",
            "    \"\"\"\n",
            "    Exposes Prometheus metrics for the application.\n",
            "    \"\"\"\n",
            "    logger.info(\"Metrics request received\")\n",
            "    return Response(generate_latest(), media_type=\"text/plain\")\n",
            "\n"
          ]
        }
      ]
    },
